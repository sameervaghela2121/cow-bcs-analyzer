PORT=4000
MONGODB_URL=mongodb://127.0.0.1:27017/bcs_tracker
JWT_ACCESS_SECRET=change-me-access
FRONTEND_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BCS Tracker <no-reply@example.com>"
GCS_BUCKET_NAME=sameerv-cow-bcs-images
GCS_PROJECT_ID=sameerv
GCS_KEY_FILE=./credentials/gcs-key.json
GCS_SIGNED_URL_EXPIRY_MS=900000

# Deployed image-compressor Cloud Function URL. Set = calls the deployed
# function (authenticated via GCS_KEY_FILE's service account, which needs
# run.invoker on it). Unset/blank = calls the image-compressor module
# in-process instead, skipping the network hop entirely.
IMAGE_COMPRESSOR_URL=

GCS_MILKING_BUCKET_NAME=sameerv-cow-milking-data

# Deployed milking-data-importer Cloud Function URL. Set = calls the deployed
# function (authenticated via GCS_KEY_FILE's service account, which needs
# run.invoker on it). Unset/blank = calls the milking-data-importer module
# in-process instead, skipping the network hop entirely.
MILKING_IMPORTER_URL=
